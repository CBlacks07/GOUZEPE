# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement pour Docker (TEMPLATE)
# Copier vers .env.docker et remplacer les valeurs avant utilisation
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (service "db" dans docker-compose) ────────────────────────────
POSTGRES_USER=gouzepe
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=EFOOTBALL

# ── API Node.js ───────────────────────────────────────────────────────────────
PGHOST=db
PGPORT=5432
PGUSER=gouzepe
PGPASSWORD=change_me_to_a_strong_password
PGDATABASE=EFOOTBALL
PGSSL=false

PORT=3005
HOST=0.0.0.0

JWT_SECRET=change_me_to_a_long_random_string
CORS_ORIGIN=*
